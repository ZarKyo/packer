#cloud-config
autoinstall:
  version: 1
  drivers:
    install: false
  identity:
    hostname: ${hostname}
    password: ${password}
    realname: ${username}
    username: ${username}
  kernel:
    package: linux-generic
  keyboard:
    layout: fr
    variant: latin9
  locale: fr_FR.UTF-8
  timezone: Europe/Paris
  packages:
    - openssh-server
    - open-vm-tools
    - cloud-init
    - whois
  early-commands:
    - systemctl stop ssh
  ssh:
    allow-pw: true
    install-server: true
  storage:
    layout:
      name: lvm
    config:
      - type: disk
        id: disk0
        match:
          size: largest
        wipe: superblock
        preserve: false
        ptable: gpt
        path: /dev/sda
      - type: partition
        id: partition0
        device: disk0
        size: 1M
        flag: bios_grub
      - type: partition
        id: partition1
        device: disk0
        size: 512M
        wipe: superblock
        flag: boot
      - type: partition
        id: partition2
        device: disk0
        size: -1
        wipe: superblock
      - type: lvm_volgroup
        id: vg0
        devices:
          - partition2
      - type: lvm_partition
        id: lv_root
        name: root
        volgroup: vg0
        size: 20G
        wipe: superblock
      - type: lvm_partition
        id: lv_home
        name: home
        volgroup: vg0
        size: 10G
        wipe: superblock
      - type: lvm_partition
        id: lv_var
        name: var
        volgroup: vg0
        size: 10G
        wipe: superblock
      - type: lvm_partition
        id: lv_swap
        name: swap
        volgroup: vg0
        size: 4G
        wipe: superblock
      - type: format
        id: format0
        volume: partition0
        fstype: ext4
      - type: format
        id: format1
        volume: partition1
        fstype: ext4
      - type: format
        id: format2
        volume: lv_root
        fstype: ext4
      - type: format
        id: format3
        volume: lv_home
        fstype: ext4
      - type: format
        id: format4
        volume: lv_var
        fstype: ext4
      - type: format
        id: format5
        volume: lv_swap
        fstype: swap
      - type: mount
        id: mount0
        device: format0
        path: /boot/efi
      - type: mount
        id: mount1
        device: format1
        path: /boot
      - type: mount
        id: mount2
        device: format2
        path: /
      - type: mount
        id: mount3
        device: format3
        path: /home
      - type: mount
        id: mount4
        device: format4
        path: /var
      - type: mount
        id: mount5
        device: format5
        path: none
  late-commands:
  - 'echo "${hostname} ALL=(ALL) NOPASSWD:ALL" > /target/etc/sudoers.d/ubuntu-nopw'
  - chmod 440 /target/etc/sudoers.d/ubuntu-nopw
  - curtin in-target --target=/target -- sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT=""/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"/' /etc/default/grub