<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!--
    ============================================================================
    Windows 11 unattended install — WIN-FOR Packer build
    ============================================================================

    Target  : VMware Workstation, UEFI/GPT, no vTPM
    Image   : Windows 11 Pro (selected by /IMAGE/NAME from the ISO's install.wim)
    Reached : via virtual floppy (Packer's `floppy_content`); Windows Setup
              auto-discovers Autounattend.xml on attached floppy/CD volumes.

    Templating
      ${username}, ${password}, ${hostname}, ${image_name} are injected by Packer
      from variables defined in winfor.pkr.hcl (templatefile() call).

    Floppy contents (from `floppy_files` in winfor.pkr.hcl)
      a:\00-fixnetwork.ps1    — force network → Private (COM)
      a:\01-enable-winrm.ps1  — full WinRM/firewall/service setup
      a:\02-enable-rdp.ps1    — enable RDP
      a:\03-win-updates.ps1   — Windows Updates loop (long, reboots)

    Packer hardware-check bypasses are applied in the windowsPE pass so the
    install proceeds on VMs without TPM 2.0 / Secure Boot / minimum RAM/CPU.
    Enabling vTPM in VMware would require full VM encryption, which we avoid.

    Setup runs in three passes (in order): windowsPE → specialize → oobeSystem.
    ============================================================================
  -->

  <!--
    ============================================================================
    Pass 1 — windowsPE
    ============================================================================
    Runs inside the Windows Preinstallation Environment (the live media), BEFORE
    any files are copied to the target disk. This is the only pass where we can:
      - bypass hardware/TPM checks (LabConfig keys read by setup.exe)
      - control disk partitioning
      - select the install image and target partition
      - accept the EULA and pre-set the registered owner
  -->
  <settings pass="windowsPE">

    <!-- Locale and keyboard layout used during setup (not the final OS locale) -->
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>040c:0000040c</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!--
        Windows 11 hardware requirement bypasses via HKLM\System\Setup\LabConfig.
        These registry keys are checked by setup.exe before installation starts.
        Without them, the installer rejects VMs that lack vTPM or meet minimum specs.
      -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add HKLM\System\Setup\LabConfig /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <!--
        GPT partition layout for UEFI boot (disk 0, wiped):
          Partition 1 — EFI system partition (500 MB, FAT32, labeled "System")
          Partition 2 — Microsoft Reserved Partition (16 MB, no format)
          Partition 3 — Windows primary partition (remaining space, NTFS, labeled "Windows")
      -->
      <DiskConfiguration>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>500</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>System</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Format>NTFS</Format>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <!--
        Selects which edition to install from the ISO by image name.
        ${image_name} is injected by Packer from the variables file (e.g. "Windows 11 Pro").
        The OS is installed onto partition 3 (the primary NTFS partition defined above).
      -->
      <ImageInstall>
        <OSImage>
          <InstallFrom>
            <MetaData wcm:action="add">
              <Key>/IMAGE/NAME</Key>
              <Value>${image_name}</Value>
            </MetaData>
          </InstallFrom>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
        </OSImage>
      </ImageInstall>

      <!--
        Product key: WillShowUI=OnError means no key prompt unless activation fails.
        AcceptEula skips the license agreement screen.
        FullName and Organization are injected by Packer.
      -->
      <UserData>
        <ProductKey>
          <WillShowUI>OnError</WillShowUI>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
        <FullName>${username}</FullName>
        <Organization>WIN-FOR</Organization>
      </UserData>

    </component>
  </settings>

  <!--
    ============================================================================
    Pass 2 — specialize
    ============================================================================
    Runs once the OS files are copied to disk and the system has booted into the
    target install (still pre-OOBE). This pass handles machine-identity settings
    (hostname, timezone, locale) and applies HKLM-level policy registry values
    while no user is logged on yet — anything we set here is in place before
    OOBE / FirstLogonCommands run.

    The big block of RunSynchronousCommand entries on the Deployment component
    locks down telemetry, advertising, location, Cortana, error reporting,
    activity history, and consumer features at machine scope (HKLM). HKCU-level
    user equivalents are applied later in oobeSystem's FirstLogonCommands.
  -->
  <settings pass="specialize">

    <!-- Sets the machine hostname and timezone injected by Packer -->
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <ComputerName>${hostname}</ComputerName>
      <TimeZone>Romance Standard Time</TimeZone>
    </component>

    <!-- Final OS locale and keyboard layout (applied to the installed system) -->
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <InputLocale>040c:0000040c</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <RunSynchronous>
        <!-- Bypass the "you must connect to a network" OOBE wall (Win11 22H2+) -->
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE /v BypassNRO /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!-- Telemetry: level 0 = Security only (minimum, policy-enforced) -->
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\DataCollection" /v AllowTelemetry /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection" /v AllowTelemetry /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection" /v MaxTelemetryAllowed /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <!-- DiagTrack (Connected User Experiences and Telemetry) service: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add "HKLM\SYSTEM\CurrentControlSet\Services\DiagTrack" /v Start /t REG_DWORD /d 4 /f</Path>
        </RunSynchronousCommand>
        <!-- WAP Push Message Routing service: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Path>reg add "HKLM\SYSTEM\CurrentControlSet\Services\dmwappushservice" /v Start /t REG_DWORD /d 4 /f</Path>
        </RunSynchronousCommand>
        <!-- DiagTrack AutoLogger: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Path>reg add "HKLM\SYSTEM\CurrentControlSet\Control\WMI\Autologger\AutoLogger-Diagtrack-Listener" /v Start /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <!-- Advertising ID: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>8</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\AdvertisingInfo" /v DisabledByGroupPolicy /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!-- Location services: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>9</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\LocationAndSensors" /v DisableLocation /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!-- Cortana and web search in Start: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>10</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\Windows Search" /v AllowCortana /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>11</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\Windows Search" /v DisableWebSearch /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>12</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\Windows Search" /v ConnectedSearchUseWeb /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <!-- Inking and typing personalization: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>13</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\InputPersonalization" /v AllowInputPersonalization /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <!-- Windows Error Reporting: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>14</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\Windows Error Reporting" /v Disabled /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>15</Order>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\Windows Error Reporting" /v Disabled /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!-- Activity History / Timeline: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>16</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\System" /v EnableActivityFeed /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>17</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\System" /v PublishUserActivities /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>18</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\System" /v UploadUserActivities /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
        <!-- Consumer features and suggested apps: disabled -->
        <RunSynchronousCommand wcm:action="add">
          <Order>19</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\CloudContent" /v DisableWindowsConsumerFeatures /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>20</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\CloudContent" /v DisableSoftLanding /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <!--
          Defender GP policy: written offline here (specialize pass runs before any
          user session, before Defender/AMSI is active) so Defender starts in
          policy-disabled mode on first boot. This prevents AMSI from blocking
          02-disable-defender.ps1 and 06-install-winfor.ps1 during provisioning.
        -->
        <RunSynchronousCommand wcm:action="add">
          <Order>21</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender" /v DisableAntiSpyware /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>22</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender" /v DisableAntiVirus /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>23</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection" /v DisableRealtimeMonitoring /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>24</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection" /v DisableBehaviorMonitoring /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>25</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection" /v DisableOnAccessProtection /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>26</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Real-Time Protection" /v DisableScanOnRealtimeEnable /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>27</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Spynet" /v SubmitSamplesConsent /t REG_DWORD /d 2 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>28</Order>
          <Path>reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows Defender\Spynet" /v SpynetReporting /t REG_DWORD /d 0 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>

  </settings>

  <!--
    ============================================================================
    Pass 3 — oobeSystem
    ============================================================================
    Runs during the Out-Of-Box Experience (the welcome wizard on first boot).
    This is the last pass; once it completes, the user session starts.

    What this pass sets up:
      - The local administrator account (${username}) — required so Packer can
        log in via WinRM.
      - AutoLogon (5 reboots) — so Packer-triggered restarts don't stall on the
        login screen.
      - OOBE screen suppression — hides EULA, OEM, online-account, wireless
        setup, etc., for a fully unattended install.
      - FirstLogonCommands — the critical block that bootstraps WinRM, RDP,
        privacy tweaks, and Windows Updates BEFORE Packer attempts its first
        winrm connection.
  -->
  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <!--
        Creates the local administrator account injected by Packer.
        PlainText=true means the password is stored as-is (acceptable for a build VM).
      -->
      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Password>
              <Value>${password}</Value>
              <PlainText>true</PlainText>
            </Password>
            <Description>WIN-FOR forensics user</Description>
            <DisplayName>${username}</DisplayName>
            <Group>Administrators</Group>
            <Name>${username}</Name>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <!--
        Auto-logs in the user up to 10 times so Packer provisioners can run
        without waiting for manual login. LogonCount decrements on each reboot.
      -->
      <AutoLogon>
        <Password>
          <Value>${password}</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <LogonCount>10</LogonCount>
        <Username>${username}</Username>
      </AutoLogon>

      <!-- Suppresses all interactive OOBE screens for a fully unattended setup -->
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Work</NetworkLocation>
        <!-- ProtectYourPC=3 disables automatic protection settings prompt -->
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <!--
        ========================================================================
        FirstLogonCommands — bootstrap sequence (runs as local admin, in order)
        ========================================================================
        These commands run synchronously on the very first user logon, BEFORE
        Packer ever attempts its first WinRM connection. The ordering matters:

          1   Set ExecutionPolicy        Allow unsigned PowerShell scripts
          2   Disable UAC                Avoid elevation prompts blocking automation
          3   Fix network → Private      Pre-requisite for WinRM (must be before #4)
          4   Configure WinRM            Listener, firewall, service auto-start
          5   Enable RDP                 Post-build remote access (port 3389)
          6-11 HKCU privacy/telemetry    User-level counterparts of HKLM tweaks
                                         from the specialize pass
          12  Install Windows Updates    Long-running; reboots, then re-enables WinRM

        Notes
          - cmd.exe /c wrapper: FirstLogonCommands runs each command via the
            shell at first-logon context. Wrapping in cmd.exe /c ensures stable
            quoting/redirection across PowerShell, .bat, and reg.exe invocations.
          - a:\ prefix: scripts come from Packer's virtual floppy, mounted as A:.
          - Floppy scripts use the `floppy-` prefix to distinguish them from
            the numbered Packer provisioner scripts (00–07, 99).
      -->
      <FirstLogonCommands>

        <!-- Order 1 — allow unsigned PowerShell scripts for the rest of the build -->
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>cmd.exe /c powershell.exe -ExecutionPolicy Bypass -NoProfile -Command "Set-ExecutionPolicy Bypass -Scope LocalMachine -Force"</CommandLine>
          <Description>Set execution policy</Description>
        </SynchronousCommand>

        <!--
          Order 2 — disable UAC (EnableLUA=0).
          Without this, Packer's elevated provisioners would trigger UAC prompts
          that no one is there to click. Restored to default by 99-cleanup.ps1.
        -->
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>cmd.exe /c reg add HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System /v EnableLUA /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable UAC for the build</Description>
        </SynchronousCommand>

        <!--
          Order 3 — force every network connection to "Private" via COM
          (INetworkListManager). MUST run before Order 4 (WinRM) because:
            - WinRM's HTTP listener and firewall rule default to Private/Domain only.
            - At first logon, Windows often hasn't classified the adapter yet, so
              Get-NetConnectionProfile / NetConnectionCategory return "Public" or
              "Unidentified" — the COM interface works regardless.
        -->
        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <CommandLine>cmd.exe /c powershell.exe -ExecutionPolicy Bypass -NoProfile -File a:\00-fixnetwork.ps1</CommandLine>
          <Description>Force network connections to Private</Description>
        </SynchronousCommand>

        <!--
          Order 4 — full WinRM bring-up (Enable-PSRemoting, listener on 5985,
          MaxTimeoutms=1800000, MaxMemoryPerShellMB=800, Basic auth,
          AllowUnencrypted, firewall rules for HTTP-In, service auto-start +
          restart). Once this returns, Packer's WinRM communicator can connect.
        -->
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <CommandLine>cmd.exe /c powershell.exe -ExecutionPolicy Bypass -NoProfile -File a:\01-enable-winrm.ps1</CommandLine>
          <Description>Enable WinRM (listener/firewall/service)</Description>
        </SynchronousCommand>

        <!-- Order 5 — enable RDP (port 3389) so the finished VM is reachable post-build -->
        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <CommandLine>cmd.exe /c powershell.exe -ExecutionPolicy Bypass -NoProfile -File a:\02-enable-rdp.ps1</CommandLine>
          <Description>Enable RDP</Description>
        </SynchronousCommand>

        <!--
          Orders 6-11 — HKCU privacy/telemetry hardening for the just-created
          ${username} account. Machine-scope (HKLM) equivalents are set in the
          specialize pass; these are the per-user counterparts that policy
          can't reach until a profile exists.
        -->

        <!-- Order 6 — disable tailored experiences (Microsoft personalized ads/tips based on diagnostic data) -->
        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Privacy" /v TailoredExperiencesWithDiagnosticDataEnabled /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable tailored experiences</Description>
        </SynchronousCommand>

        <!-- Order 7 — disable the per-user advertising ID used by UWP apps for ad targeting -->
        <SynchronousCommand wcm:action="add">
          <Order>7</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\AdvertisingInfo" /v Enabled /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable advertising ID</Description>
        </SynchronousCommand>

        <!--
          Orders 8-10 — disable inking/typing personalization (collection of
          handwriting samples, typed text, and contact harvesting that Windows
          uses to "improve" predictions and IME).
        -->
        <SynchronousCommand wcm:action="add">
          <Order>8</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\InputPersonalization" /v RestrictImplicitInkCollection /t REG_DWORD /d 1 /f</CommandLine>
          <Description>Disable implicit ink collection</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>9</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\InputPersonalization" /v RestrictImplicitTextCollection /t REG_DWORD /d 1 /f</CommandLine>
          <Description>Disable implicit text collection</Description>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>10</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\InputPersonalization\TrainedDataStore" /v HarvestContacts /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable contact harvesting for typing personalization</Description>
        </SynchronousCommand>

        <!-- Order 11 — suppress the periodic "How are we doing?" feedback prompts -->
        <SynchronousCommand wcm:action="add">
          <Order>11</Order>
          <CommandLine>cmd.exe /c reg add "HKCU\SOFTWARE\Microsoft\Siuf\Rules" /v NumberOfSIUFInPeriod /t REG_DWORD /d 0 /f</CommandLine>
          <Description>Disable feedback prompts</Description>
        </SynchronousCommand>

        <!--
          Order 12 — Windows Updates loop (a:\09-win-updates.ps1).
          This is the long one: polls Microsoft Update, downloads applicable
          updates, installs them, reboots when needed, and resumes via a Run
          registry entry (HKLM\...\CurrentVersion\Run\InstallWindowsUpdates)
          until no updates remain. Expect 30 min to a few hours depending on
          the ISO baseline.

          Why we don't add an Order 13 to re-enable WinRM after this:
          FirstLogonCommands terminates as soon as Order 12 returns (which is
          on the FIRST Restart-Computer inside win-updates.ps1). After that
          first reboot, the script resumes via the Run key — NOT via
          FirstLogonCommands. So an Order 13 here would fire too early and
          never run after the LAST WU-triggered reboot. Instead, the script
          itself calls a:\07-enable-winrm.ps1 on each of its 3 exit paths
          (cycle limit, normal end, no updates found), guaranteeing WinRM is
          restored on the actual final iteration.
        -->
        <SynchronousCommand wcm:action="add">
          <Order>12</Order>
          <CommandLine>cmd.exe /c powershell.exe -ExecutionPolicy Bypass -NoProfile -File a:\03-win-updates.ps1</CommandLine>
          <Description>Install Windows Updates</Description>
        </SynchronousCommand>

      </FirstLogonCommands>

      <RegisteredOrganization>WIN-FOR</RegisteredOrganization>
      <RegisteredOwner>${username}</RegisteredOwner>
      <TimeZone>Romance Standard Time</TimeZone>

    </component>
  </settings>

</unattend>
